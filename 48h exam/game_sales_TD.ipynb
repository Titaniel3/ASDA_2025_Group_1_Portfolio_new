    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Predict on test set (log scale)\\n\",\n",
    "    \"y_pred_log = pipe.predict(X_test)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Back-transform to original sales scale\\n\",\n",
    "    \"y_test_sales = np.expm1(y_test)\\n\",\n",
    "    \"y_pred_sales = np.expm1(y_pred_log)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Absolute + relative errors (original scale)\\n\",\n",
    "    \"abs_err = np.abs(y_test_sales - y_pred_sales)\\n\",\n",
    "    \"pct_err = abs_err / np.clip(y_test_sales, 1e-9, None)  # avoid divide-by-zero\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Summary metrics\\n\",\n",
    "    \"from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\\n\",\n",
    "    \"\\n\",\n",
    "    \"rmse_log = np.sqrt(mean_squared_error(y_test, y_pred_log))\\n\",\n",
    "    \"mae_log = mean_absolute_error(y_test, y_pred_log)\\n\",\n",
    "    \"r2_log = r2_score(y_test, y_pred_log)\\n\",\n",
    "    \"\\n\",\n",
    "    \"rmse_sales = np.sqrt(mean_squared_error(y_test_sales, y_pred_sales))\\n\",\n",
    "    \"mae_sales = mean_absolute_error(y_test_sales, y_pred_sales)\\n\",\n",
    "    \"r2_sales = r2_score(y_test_sales, y_pred_sales)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"LOG SCALE:\\\")\\n\",\n",
    "    \"print(f\\\"  RMSE: {rmse_log:.4f} | MAE: {mae_log:.4f} | R2: {r2_log:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nORIGINAL SALES SCALE:\\\")\\n\",\n",
    "    \"print(f\\\"  RMSE: {rmse_sales:.4f} | MAE: {mae_sales:.4f} | R2: {r2_sales:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Precision-style reporting (robust percentiles)\\n\",\n",
    "    \"print(\\\"\\\\nABS ERROR (sales) percentiles:\\\")\\n\",\n",
    "    \"print(abs_err.quantile([0.5, 0.75, 0.9, 0.95]).to_string())\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nPERCENT ERROR percentiles (only where true sales > 0.1):\\\")\\n\",\n",
    "    \"mask = y_test_sales > 0.1\\n\",\n",
    "    \"print(pct_err[mask].quantile([0.5, 0.75, 0.9, 0.95]).to_string())\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Show worst predictions (largest absolute errors)\\n\",\n",
    "    \"results = X_test.copy()\\n\",\n",
    "    \"results[\\\"true_sales\\\"] = y_test_sales.values\\n\",\n",
    "    \"results[\\\"pred_sales\\\"] = y_pred_sales\\n\",\n",
    "    \"results[\\\"abs_err\\\"] = abs_err.values\\n\",\n",
    "    \"results[\\\"pct_err\\\"] = pct_err.values\\n\",\n",
    "    \"\\n\",\n",
    "    \"results.sort_values(\\\"abs_err\\\", ascending=False).head(20)\"\n",
    "   ],\n",
