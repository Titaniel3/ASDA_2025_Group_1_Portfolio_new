    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-28T09:29:03.082219Z\",\n",
    "     \"start_time\": \"2026-02-28T09:29:03.069805Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 2) train/test split (time-aware to avoid leakage)\\n\",\n",
    "    \"# choose a cutoff year; here: last ~3 years in dataset become test\\n\",\n",
    "    \"cutoff = df[\\\"Year\\\"].quantile(0.95)\\n\",\n",
    "    \"cutoff = int(cutoff)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_mask = df[\\\"Year\\\"] < cutoff\\n\",\n",
    "    \"test_mask = ~train_mask\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_train, X_test = X.loc[train_mask], X.loc[test_mask]\\n\",\n",
    "    \"y_train, y_test = y.loc[train_mask], y.loc[test_mask]\\n\",\n",
    "    \"\\n\",\n",
    "    \"cutoff, X_train.shape, X_test.shape\"\n",
    "   ],\n",
