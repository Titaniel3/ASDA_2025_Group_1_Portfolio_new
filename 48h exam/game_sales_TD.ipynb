    "    \"by_gen = (\\n\",\n",
    "    \"    df.loc[df[\\\"Platform\\\"].isin(platforms) & df[\\\"Year\\\"].notna(), [\\\"Year\\\", \\\"Platform\\\", \\\"Global_Sales\\\"]]\\n\",\n",
    "    \"      .assign(Year=lambda x: x[\\\"Year\\\"].astype(int))\\n\",\n",
    "    \"      .groupby([\\\"Year\\\", \\\"Platform\\\"], as_index=False)[\\\"Global_Sales\\\"]\\n\",\n",
    "    \"      .sum()\\n\",\n",
    "    \"      .sort_values([\\\"Platform\\\", \\\"Year\\\"])\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(14, 6))\\n\",\n",
    "    \"ax.bar(total[\\\"Year\\\"], total[\\\"Global_Sales\\\"], alpha=0.25, width=0.8, label=\\\"Total (Family)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.lineplot(data=by_gen, x=\\\"Year\\\", y=\\\"Global_Sales\\\", hue=\\\"Platform\\\",\\n\",\n",
    "    \"             marker=\\\"o\\\", linewidth=2, ax=ax)\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax.set_title(f\\\"{title}: Total Sales (bars) + Generation Sales (lines)\\\")\\n\",\n",
