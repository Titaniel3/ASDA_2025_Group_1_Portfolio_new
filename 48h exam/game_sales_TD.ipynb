    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# select relevant columns for training\\n\",\n",
    "    \"\\n\",\n",
    "    \"cols = [\\\"Platform\\\", \\\"Year\\\", \\\"Genre\\\", \\\"Publisher\\\", \\\"Global_Sales\\\"]\\n\",\n",
    "    \"df = df[cols].dropna(subset=[\\\"Platform\\\", \\\"Year\\\", \\\"Genre\\\", \\\"Publisher\\\", \\\"Global_Sales\\\"]).copy()\\n\",\n",
    "    \"df[\\\"Year\\\"] = df[\\\"Year\\\"].astype(int)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# target (log)\\n\",\n",
    "    \"y = np.log1p(df[\\\"Global_Sales\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"X = df[[\\\"Platform\\\", \\\"Year\\\", \\\"Genre\\\", \\\"Publisher\\\"]]\"\n",
    "   ],\n",
    "   \"id\": \"c0b8ddcb6b2ee093\",\n",
    "   \"outputs\": [],\n",
