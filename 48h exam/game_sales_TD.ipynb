    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# Preperation for training: Merge all platform with <50 observations into \\\"Other\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"platform_counts = df[\\\"Platform\\\"].value_counts()\\n\",\n",
    "    \"\\n\",\n",
    "    \"valid_platforms = platform_counts[platform_counts >= 50].index\\n\",\n",
    "    \"\\n\",\n",
    "    \"# create training platform column\\n\",\n",
    "    \"df[\\\"Platform_train\\\"] = df[\\\"Platform\\\"].where(\\n\",\n",
    "    \"    df[\\\"Platform\\\"].isin(valid_platforms),\\n\",\n",
    "    \"    \\\"Other\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# quick check\\n\",\n",
    "    \"df[\\\"Platform_train\\\"].value_counts()\"\n",
