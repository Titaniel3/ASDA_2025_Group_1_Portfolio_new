    "   \"source\": [\n",
    "    \"ps_platforms = [\\\"PS\\\", \\\"PS2\\\", \\\"PS3\\\", \\\"PS4\\\", \\\"PSP\\\", \\\"PSV\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# aggregate totals per year (numeric Year)\\n\",\n",
    "    \"total = (\\n\",\n",
    "    \"    df.loc[df[\\\"Platform\\\"].isin(ps_platforms) & df[\\\"Year\\\"].notna(), [\\\"Year\\\", \\\"Global_Sales\\\"]]\\n\",\n",
