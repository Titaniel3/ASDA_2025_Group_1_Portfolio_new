    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 7) optional: evaluate in original sales scale (interpretability)\\n\",\n",
    "    \"# note: metrics on original scale are dominated by blockbusters; keep log metrics as primary\\n\",\n",
    "    \"sales_true = np.expm1(y_test)\\n\",\n",
    "    \"sales_pred = np.expm1(y_pred)\\n\",\n",
    "    \"\\n\",\n",
    "    \"rmse_sales = np.sqrt(mean_squared_error(sales_true, sales_pred))\\n\",\n",
    "    \"mae_sales = mean_absolute_error(sales_true, sales_pred)\\n\",\n",
    "    \"r2_sales = r2_score(sales_true, sales_pred)\\n\",\n",
    "    \"\\n\",\n",
    "    \"rmse_sales, mae_sales, r2_sales\"\n",
